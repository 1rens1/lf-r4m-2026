https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_forever\" x=\"205\" y=\"0\"></block></xml>","main.ts":"","README.md":"","pxt.json":"{\n    \"name\": \"lf-r4m-2026\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}},{"timestamp":1774419007615,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_button_event\" x=\"302\" y=\"219\"><field name=\"NAME\">Button.A</field><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # . \n        # . . . # \n        # # # # . \n        # . . . # \n        # . . . #\n        `</field></block></statement></block><block type=\"device_button_event\" x=\"560\" y=\"216\"><field name=\"NAME\">Button.B</field><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        . # # # . \n        # . . . . \n        # . # # . \n        # . . . # \n        . # # # .\n        `</field></block></statement></block><block type=\"device_forever\" x=\"853\" y=\"210\"><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # . \n        # . . . # \n        # # # # . \n        # . . . # \n        # # # # .\n        `</field></block></statement></block></xml>","main.ts":"/*\n * Line follower for R4M National 2026 - Indonesia\n * Used PID Algorithm, reference: https://robotresearchlab.com/2019/02/16/pid-line-follower-tuning/\n * by rens\n *\n * Pins:\n * +-----------------+\n * | [ ] [ ] [ ] BTN | Button\n * | [ ] [ ] MTL MTR | Motors\n * +-----------------+\n * | . L R . . . . . | Sensors\n * +-----------------+\n */\n\n// 0-255\nconst Motor = {\n    // 0-255\n    MAX_SPEED: 200,\n    // 0-255\n    BASE_SPEED: 80,\n    // [Control Pin, Speed Pin]\n    LEFT: [AnalogPin.P13, AnalogPin.P14],\n    RIGHT: [AnalogPin.P15, AnalogPin.P16],\n\n    set: (motor: AnalogPin[], ctrl: number, speed: number) => {\n        sensors.DDMmotor(motor[0], ctrl, motor[1], speed);\n    }\n}\nconst Sensor = {\n    LEFT: DigitalPin.P8,\n    RIGHT: DigitalPin.P12,\n\n    isOnLine: (sensor: DigitalPin) => pins.digitalReadPin(sensor) == 1\n}\n\nconst ForceSensor = {\n    MAIN: DigitalPin.P20,\n\n    isPressed: (forceSensor: DigitalPin = null) =>\n        pins.digitalReadPin(forceSensor == null ? ForceSensor.MAIN : forceSensor) == 0\n}\n\n// function showIcon(icon: IconNames, duration = 0) {\n//     basic.showIcon(icon, 0);\n//     basic.pause(duration);\n// }\n\nconst routes: ['R', 'G', 'B'] = ['R', 'G', 'B'];\ntype Route = typeof routes[number]\n\nconst start = (route: Route) => {\n    switch (route) {\n        case \"R\":\n            basic.showLeds(`\n                # # # # .\n                # . . . #\n                # # # # .\n                # . . . #\n                # . . . #\n            `)\n            break\n        case \"G\":\n            basic.showLeds(`\n                . # # # .\n                # . . . .\n                # . # # .\n                # . . . #\n                . # # # .\n            `)\n            break\n        case \"B\":\n            basic.showLeds(`\n                # # # # .\n                # . . . #\n                # # # # .\n                # . . . #\n                # # # # .\n            `)\n            break\n    }\n\n    Motor.set(Motor.LEFT, 0, 255)\n    Motor.set(Motor.RIGHT, 0, 255)\n\n    basic.pause(1000);\n}\n\n\ninput.onButtonPressed(Button.A, () => {\n    start(\"R\");\n})\ninput.onButtonPressed(Button.B, () => {\n    start(\"G\");\n})\nbasic.forever(() => {\n    start(\"B\");\n})","README.md":"","pxt.json":"{\n    \"name\": \"lf-r4m-2026\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"sensors\": \"github:gigotoys/gigo-block#b900a6ceabfc9757eb5b5c308f2d2a440dc58785\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1774858263909,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_button_event\" x=\"302\" y=\"219\"><field name=\"NAME\">Button.A</field><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # . \n        # . . . # \n        # # # # . \n        # . . . # \n        # . . . #\n        `</field></block></statement></block><block type=\"device_button_event\" x=\"560\" y=\"216\"><field name=\"NAME\">Button.B</field><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        . # # # . \n        # . . . . \n        # . # # . \n        # . . . # \n        . # # # .\n        `</field></block></statement></block><block type=\"device_forever\" x=\"853\" y=\"210\"><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # . \n        # . . . # \n        # # # # . \n        # . . . # \n        # # # # .\n        `</field></block></statement></block></xml>","main.ts":"/*\n * Line follower for R4M National 2026 - Indonesia\n * Used PID Algorithm, reference: https://robotresearchlab.com/2019/02/16/pid-line-follower-tuning/\n * by rens\n *\n * Pins:\n * +-----------------+\n * | [ ] [ ] [ ] BTN | Button\n * | [ ] [ ] MTL MTR | Motors\n * +-----------------+\n * | . L R . . . . . | Sensors\n * +-----------------+\n */\n\nconst Motor = {\n    // 0-255\n    MAX_SPEED: 200,\n    // 0-255\n    BASE_SPEED: 80,\n    // [Control Pin, Speed Pin]\n    LEFT: [AnalogPin.P13, AnalogPin.P14],\n    RIGHT: [AnalogPin.P15, AnalogPin.P16],\n\n    set: (motor: AnalogPin[], ctrl: number, speed: number) => {\n        sensors.DDMmotor(motor[0], ctrl, motor[1], speed);\n    }\n}\n\nconst setMotor = (motor: AnalogPin[], forwardCtrl: number, speed: number) => {\n    const reverseCtrl = forwardCtrl === 0 ? 1 : 0;\n    if (speed >= 0) {\n        Motor.set(motor, forwardCtrl, Math.min(speed, Motor.MAX_SPEED));\n    } else {\n        Motor.set(motor, reverseCtrl, Math.min(-speed, Motor.MAX_SPEED));\n    }\n}\n\nconst Sensor = {\n    LEFT: DigitalPin.P8,\n    RIGHT: DigitalPin.P12,\n\n    isOnLine: (sensor: DigitalPin) => pins.digitalReadPin(sensor) == 1\n}\n\nconst ForceSensor = {\n    MAIN: DigitalPin.P20,\n\n    isPressed: (forceSensor: DigitalPin = null) =>\n        pins.digitalReadPin(forceSensor == null ? ForceSensor.MAIN : forceSensor) == 0\n}\n\nconst showRouteIcon = (route: Route) => {\n    switch (route) {\n        case \"R\":\n            basic.showLeds(`\n                . . . . .\n                . . # . .\n                . # . # .\n                . # . . .\n                . # . . .\n            `, 0)\n            break\n        case \"G\":\n            basic.showLeds(`\n                . . . . .\n                . . # . .\n                . # . # .\n                . . # # .\n                . # # # .\n            `, 0)\n            break\n        case \"B\":\n            basic.showLeds(`\n                . . . . .\n                . # . . .\n                . # # . .\n                . # . # .\n                . # # . .\n            `, 0)\n            break\n    }\n}\n\nconst routes: ['R', 'G', 'B'] = ['R', 'G', 'B'];\ntype Route = typeof routes[number];\n\nconst start = (route: Route) => {\n    basic.showArrow(ArrowNames.North, 0);\n\n    Motor.set(Motor.LEFT, 0, Motor.MAX_SPEED);\n    Motor.set(Motor.RIGHT, 1, Motor.MAX_SPEED);\n\n    basic.pause(1000);\n\n    showRouteIcon(route);\n\n    const Kp = Motor.BASE_SPEED * 2.5;\n    const Ki = 0;\n    const Kd = 0;\n    let [P, I, D, lastError] = [0, 0, 0, 0];\n\n    while (true) {\n        const leftOnLine = Sensor.isOnLine(Sensor.LEFT);\n        const rightOnLine = Sensor.isOnLine(Sensor.RIGHT);\n\n        if (leftOnLine) led.plot(0, 0); else led.unplot(0, 0);\n        if (rightOnLine) led.plot(4, 0); else led.unplot(4, 0);\n\n        /* PID ALGORITHM */\n        let error = 0;\n        if (leftOnLine && !rightOnLine) { // drifting right\n            error = 1;\n        } else if (!leftOnLine && rightOnLine) { // drifting left\n            error = -1;\n        } else if (leftOnLine && rightOnLine) { // terminate\n            break;\n        }\n\n        P = error;\n        I = I + error;\n        D = error - lastError;\n        lastError = error;\n\n        const correction = (Kp * P) + (Ki * I) + (Kd * D);\n\n        setMotor(Motor.LEFT, 0, Motor.BASE_SPEED - correction);\n        setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED + correction);\n    }\n\n    switch (route) {\n        case \"R\":\n            setMotor(Motor.LEFT, 0, Motor.MAX_SPEED);\n            setMotor(Motor.RIGHT, 0, Motor.MAX_SPEED);\n            basic.pause(600);\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(300);\n            break\n        case \"G\":\n            setMotor(Motor.LEFT, 0, Motor.MAX_SPEED);\n            setMotor(Motor.RIGHT, 0, Motor.MAX_SPEED);\n            basic.pause(600);\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(300);\n            break\n        case \"B\":\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(1000);\n            setMotor(Motor.LEFT, 0, 0);\n            setMotor(Motor.RIGHT, 1, 0);\n            basic.pause(50);\n            setMotor(Motor.LEFT, 1, Motor.MAX_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.MAX_SPEED);\n            basic.pause(1500);\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(400);\n            break\n    }\n\n    Motor.set(Motor.LEFT, 0, 0);\n    Motor.set(Motor.RIGHT, 1, 0);\n\n    basic.showIcon(IconNames.Diamond, 0);\n}\n\n\ninput.onButtonPressed(Button.A, () => {\n    start(\"R\");\n})\ninput.onButtonPressed(Button.B, () => {\n    start(\"G\");\n})\nbasic.forever(() => {\n    if (ForceSensor.isPressed(ForceSensor.MAIN)) {\n        start(\"B\");\n    }\n})\n\nbasic.showIcon(IconNames.Diamond, 0);","README.md":"","pxt.json":"{\n    \"name\": \"lf-r4m-2026\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"sensors\": \"github:gigotoys/gigo-block#b900a6ceabfc9757eb5b5c308f2d2a440dc58785\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1775553190895,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block><block type=\"device_button_event\" x=\"302\" y=\"219\"><field name=\"NAME\">Button.A</field><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # . \n        # . . . # \n        # # # # . \n        # . . . # \n        # . . . #\n        `</field></block></statement></block><block type=\"device_button_event\" x=\"560\" y=\"216\"><field name=\"NAME\">Button.B</field><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        . # # # . \n        # . . . . \n        # . # # . \n        # . . . # \n        . # # # .\n        `</field></block></statement></block><block type=\"device_forever\" x=\"853\" y=\"210\"><statement name=\"HANDLER\"><block type=\"device_show_leds\"><field name=\"LEDS\">`\n        # # # # . \n        # . . . # \n        # # # # . \n        # . . . # \n        # # # # .\n        `</field></block></statement></block></xml>","main.ts":"/*\n * Line follower for R4M National 2026 - Indonesia\n * Used PID Algorithm, reference: https://robotresearchlab.com/2019/02/16/pid-line-follower-tuning/\n * by rens\n *\n * Pins:\n * +-----------------+\n * | [ ] [ ] [ ] BTN | Button\n * | [ ] [ ] MTL MTR | Motors\n * +-----------------+\n * | . L R . . . . . | Sensors\n * +-----------------+\n */\n\nconst Motor = {\n    // 0-255\n    MAX_SPEED: 200,\n    // 0-255\n    BASE_SPEED: 80,\n    // [Control Pin, Speed Pin]\n    LEFT: [AnalogPin.P13, AnalogPin.P14],\n    RIGHT: [AnalogPin.P15, AnalogPin.P16],\n\n    set: (motor: AnalogPin[], ctrl: number, speed: number) => {\n        sensors.DDMmotor(motor[0], ctrl, motor[1], speed);\n    }\n}\n\nconst setMotor = (motor: AnalogPin[], forwardCtrl: number, speed: number) => {\n    const reverseCtrl = forwardCtrl === 0 ? 1 : 0;\n    if (speed >= 0) {\n        Motor.set(motor, forwardCtrl, Math.min(speed, Motor.MAX_SPEED));\n    } else {\n        Motor.set(motor, reverseCtrl, Math.min(-speed, Motor.MAX_SPEED));\n    }\n}\n\nconst Sensor = {\n    LEFT: DigitalPin.P8,\n    RIGHT: DigitalPin.P12,\n\n    isOnLine: (sensor: DigitalPin) => pins.digitalReadPin(sensor) == 1\n}\n\nconst ForceSensor = {\n    MAIN: DigitalPin.P20,\n\n    isPressed: (forceSensor: DigitalPin = null) =>\n        pins.digitalReadPin(forceSensor == null ? ForceSensor.MAIN : forceSensor) == 0\n}\n\nconst showRouteIcon = (route: Route) => {\n    switch (route) {\n        case \"R\":\n            basic.showLeds(`\n                . . . . .\n                . . # . .\n                . # . # .\n                . # . . .\n                . # . . .\n            `, 0)\n            break\n        case \"G\":\n            basic.showLeds(`\n                . . . . .\n                . . # . .\n                . # . # .\n                . . # # .\n                . # # # .\n            `, 0)\n            break\n        case \"B\":\n            basic.showLeds(`\n                . . . . .\n                . # . . .\n                . # # . .\n                . # . # .\n                . # # . .\n            `, 0)\n            break\n    }\n}\n\nconst routes: ['R', 'G', 'B'] = ['R', 'G', 'B'];\ntype Route = typeof routes[number];\n\nconst start = (route: Route) => {\n    basic.showArrow(ArrowNames.North, 0);\n\n    Motor.set(Motor.LEFT, 0, Motor.MAX_SPEED);\n    Motor.set(Motor.RIGHT, 1, Motor.MAX_SPEED);\n\n    basic.pause(1000);\n\n    showRouteIcon(route);\n\n    const Kp = Motor.BASE_SPEED * ((route === 'B') ? 2.5 : 2);\n    const Ki = 0;\n    const Kd = 0;\n    let [P, I, D, lastError] = [0, 0, 0, 0];\n\n    while (true) {\n        const leftOnLine = Sensor.isOnLine(Sensor.LEFT);\n        const rightOnLine = Sensor.isOnLine(Sensor.RIGHT);\n\n        if (leftOnLine) led.plot(0, 0); else led.unplot(0, 0);\n        if (rightOnLine) led.plot(4, 0); else led.unplot(4, 0);\n\n        /* PID ALGORITHM */\n        let error = 0;\n        if (leftOnLine && !rightOnLine) { // drifting right\n            error = 1;\n        } else if (!leftOnLine && rightOnLine) { // drifting left\n            error = -1;\n        } else if (leftOnLine && rightOnLine) { // terminate\n            break;\n        }\n\n        P = error;\n        I = I + error;\n        D = error - lastError;\n        lastError = error;\n\n        const correction = (Kp * P) + (Ki * I) + (Kd * D);\n\n        setMotor(Motor.LEFT, 0, Motor.BASE_SPEED - correction);\n        setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED + correction);\n    }\n\n    switch (route) {\n        case \"R\":\n            setMotor(Motor.LEFT, 0, Motor.MAX_SPEED);\n            setMotor(Motor.RIGHT, 0, Motor.MAX_SPEED);\n            basic.pause(650);\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(300);\n            break\n        case \"G\":\n            setMotor(Motor.LEFT, 0, Motor.MAX_SPEED);\n            setMotor(Motor.RIGHT, 0, Motor.MAX_SPEED);\n            basic.pause(650);\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(300);\n            break\n        case \"B\":\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(1200);\n            setMotor(Motor.LEFT, 0, 0);\n            setMotor(Motor.RIGHT, 1, 0);\n            basic.pause(50);\n            setMotor(Motor.LEFT, 1, Motor.MAX_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.MAX_SPEED);\n            basic.pause(1000);\n            setMotor(Motor.LEFT, 0, Motor.BASE_SPEED);\n            setMotor(Motor.RIGHT, 1, Motor.BASE_SPEED);\n            basic.pause(200);\n            break\n    }\n\n    Motor.set(Motor.LEFT, 0, 0);\n    Motor.set(Motor.RIGHT, 1, 0);\n\n    basic.showIcon(IconNames.Diamond, 0);\n}\n\n\ninput.onButtonPressed(Button.A, () => {\n    start(\"R\");\n})\ninput.onButtonPressed(Button.B, () => {\n    start(\"G\");\n})\nbasic.forever(() => {\n    if (ForceSensor.isPressed(ForceSensor.MAIN)) {\n        start(\"B\");\n    }\n})\n\nbasic.showIcon(IconNames.Diamond, 0);","README.md":"","pxt.json":"{\n    \"name\": \"lf-r4m-2026\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"sensors\": \"github:gigotoys/gigo-block#b900a6ceabfc9757eb5b5c308f2d2a440dc58785\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776252872710,"editorVersion":"8.0.21","text":{"main.bloc